{
  "version": 2,
  "builds": [
    {
      "src": "backend/smart_food_network/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "build_files.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "backend/staticfiles"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "backend/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "backend/smart_food_network/wsgi.py"
    }
  ]
}
